{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "source .venv/bin/activate && uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-l", "-c"]
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Uvicorn running on.*|.*Started reloader process.*",
          "endsPattern": ".*Application startup complete.*"
        }
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-l", "-c"]
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*next dev.*|.*Starting.*",
          "endsPattern": ".*Ready in.*"
        }
      }
    },
    {
      "label": "Start App",
      "dependsOrder": "parallel",
      "dependsOn": ["Start Backend", "Start Frontend"]
    }
  ]
}