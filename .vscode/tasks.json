{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend 🔧",
      "type": "shell",
      "command": "source .venv/bin/activate && uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-l", "-c"]
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(?!)$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Started reloader process.*|.*Uvicorn running on.*",
          "endsPattern": ".*Application startup complete.*"
        }
      }
    },
    {
      "label": "Frontend 🎨",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-l", "-c"]
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(?!)$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*next dev.*|.*Starting.*",
          "endsPattern": ".*Ready in.*|.*Local:.*http://localhost:3000.*"
        }
      }
    },
    {
      "label": "Start RideRecon",
      "dependsOrder": "parallel",
      "dependsOn": ["Backend 🔧", "Frontend 🎨"]
    }
  ]
}